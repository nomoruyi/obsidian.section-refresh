{
	"name": "section-refresh",
	"version": "0.1.0",
	"description": "A one-click refresh button on opt-in headings that resets every checkbox in that section.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"obsidian-md"
	],
	"author": "nomoruyi",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.20.0",
		"obsidian": "latest",
		"tslib": "^2.6.0",
		"typescript": "^5.4.0",
		"vitest": "^1.6.0"
	}
}
